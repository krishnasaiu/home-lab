[Unit]
Description=Dispatcharr Container
After=network-online.target

[Container]
ContainerName=dispatcharr
Image=ghcr.io/dispatcharr/dispatcharr:latest
PublishPort=9191:9191
Volume=%h/.config/storage/dispatcharr:/data:Z
Network=dns.network
IP=10.89.0.100
PodmanArgs=--network-alias=dispatcharr

[Install]
WantedBy=default.target

[Service]
Restart=always
TimeoutStartSec=900
